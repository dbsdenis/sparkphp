    <!-- ── Quick Start ── -->
    <section>
        <div class="docs-section-head">
            <span class="section-tag">Começando</span>
            <h2>Quick Start</h2>
        </div>

        <div class="docs-code-window">
            <div class="docs-code-bar">
                <div class="docs-code-dots"><span></span><span></span><span></span></div>
                <span class="docs-code-label">terminal</span>
                <button class="docs-code-copy" onclick="copyCode(this)">Copiar</button>
            </div>
            <pre><?php echo <<<'HTML'
<span class="line-comment"># 1. Clone e instale</span>
git clone https://github.com/seu-usuario/sparkphp.git meu-app
cd meu-app && <span class="line-keyword">composer install</span>

<span class="line-comment"># 2. Configure</span>
cp .env.example .env
<span class="line-comment"># edite .env com suas credenciais</span>

<span class="line-comment"># 3. Rode</span>
<span class="line-keyword">php spark serve</span>

<span class="line-comment"># Ou gere um projeto novo ja com starter first-party</span>
<span class="line-keyword">php spark new ../meu-saas --starter=saas</span>

<span class="line-comment"># Acesse http://localhost:8000 — pronto</span>
HTML; ?></pre>
        </div>
    </section>

    <!-- ── First Route Examples ── -->
    <section>
        <div class="docs-section-head">
            <span class="section-tag">Primeiros passos</span>
            <h2>Sua primeira rota</h2>
        </div>

        <div class="docs-code-window" style="margin-bottom: 1.5rem;">
            <div class="docs-code-bar">
                <div class="docs-code-dots"><span></span><span></span><span></span></div>
                <span class="docs-code-label">app/routes/hello.php</span>
                <button class="docs-code-copy" onclick="copyCode(this)">Copiar</button>
            </div>
            <pre><?php echo <<<'HTML'
