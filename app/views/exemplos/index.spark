<script>
    function switchTab(tabId) {
        document.querySelectorAll('.exemplos-tab').forEach(t => {
            const isActive = t.dataset.tab === tabId;
            t.classList.toggle('active', isActive);
            t.setAttribute('aria-selected', isActive ? 'true' : 'false');
            t.tabIndex = isActive ? 0 : -1;
        });

        document.querySelectorAll('.exemplo-panel').forEach(p => {
            const isActive = p.dataset.panel === tabId;
            p.classList.toggle('active', isActive);
            p.hidden = !isActive;
        });
    }

    const exemploTabs = Array.from(document.querySelectorAll('.exemplos-tab'));

    exemploTabs.forEach((tab, index) => {
        tab.addEventListener('click', () => switchTab(tab.dataset.tab));
        tab.addEventListener('keydown', event => {
            const horizontalKeys = ['ArrowRight', 'ArrowLeft'];
            const verticalKeys = ['ArrowDown', 'ArrowUp'];

            if (![...horizontalKeys, ...verticalKeys, 'Home', 'End'].includes(event.key)) {
                return;
            }

            event.preventDefault();

            let nextIndex = index;

            if (event.key === 'Home') {
                nextIndex = 0;
            } else if (event.key === 'End') {
                nextIndex = exemploTabs.length - 1;
            } else if (event.key === 'ArrowRight' || event.key === 'ArrowDown') {
                nextIndex = (index + 1) % exemploTabs.length;
            } else if (event.key === 'ArrowLeft' || event.key === 'ArrowUp') {
                nextIndex = (index - 1 + exemploTabs.length) % exemploTabs.length;
            }

            exemploTabs[nextIndex].focus();
            switchTab(exemploTabs[nextIndex].dataset.tab);
        });
    });

    function toggleOutput(btn) {
        const output = btn.nextElementSibling;
        output.classList.toggle('visible');
        btn.innerHTML = output.classList.contains('visible')
            ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16"></rect><rect x="14" y="4" width="4" height="16"></rect></svg> Esconder output'
            : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg> Ver output';
    }
</script>
<script src="{{ asset('js/copy-code.js') }}"></script>
