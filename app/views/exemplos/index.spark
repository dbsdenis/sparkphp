<span class="line-comment">// app/routes/api/summarize.php</span>

<span class="line-keyword">post</span>(<span class="line-fn">function</span> () {
    <span class="line-var">$text</span> = <span class="line-fn">input</span>(<span class="line-string">'text'</span>);

    <span class="line-var">$result</span> = <span class="line-fn">ai</span>()
        -><span class="line-fn">text</span>(<span class="line-string">"Resuma o texto a seguir em 3 bullets:\n\n{$text}"</span>)
        -><span class="line-fn">system</span>(<span class="line-string">'Seja objetivo.'</span>)
        -><span class="line-fn">maxTokens</span>(300)
        -><span class="line-fn">generate</span>();

    <span class="line-keyword">return</span> [<span class="line-string">'summary'</span> => <span class="line-var">$result</span>->text];
});
