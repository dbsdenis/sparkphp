<span class="line-comment">// app/routes/search.php</span>

<span class="line-keyword">get</span>(<span class="line-fn">function</span> () {
    <span class="line-var">$q</span> = <span class="line-fn">query</span>(<span class="line-string">'q'</span>, <span class="line-string">'Como funciona o cache?'</span>);

    <span class="line-var">$articles</span> = <span class="line-var">Article</span>::<span class="line-fn">semanticSearch</span>(<span class="line-string">'embedding'</span>, <span class="line-var">$q</span>)
