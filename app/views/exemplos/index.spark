        <div class="exemplos-content">
            <!-- Hello World -->
            <div class="exemplo-panel active" id="panel-hello" data-panel="hello" role="tabpanel" aria-labelledby="tab-hello">
                <h2>Hello World</h2>
                <p>A rota mais simples possível — um arquivo, uma função, JSON na resposta.</p>

                <div class="code-window code-window--spaced">
                    <div class="code-window__bar">
                        <div class="code-window__dots"><span></span><span></span><span></span></div>
                        <span class="code-window__label">código</span>
                        <button class="code-window__copy" onclick="copyCode(this)">&#128203; Copiar</button>
                    </div>
                    <pre><?php echo <<<'HTML'
<span class="line-comment">// app/routes/hello.php</span>

<span class="line-keyword">get</span>(<span class="line-fn">fn</span>() => [<span class="line-string">'message'</span> => <span class="line-string">'Hello, SparkPHP!'</span>]);

<span class="line-comment">// Acesse: GET /hello</span>
<span class="line-comment">// Retorna: {"message": "Hello, SparkPHP!"}</span>
HTML; ?></pre>
                </div>

                <button class="ex-output-btn" onclick="toggleOutput(this)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                    Ver output
                </button>

                <div class="ex-output">
<span class="output-status">HTTP/1.1 200 OK</span>
Content-Type: application/json

{
  <strong>"message"</strong>: "Hello, SparkPHP!"
}</div>
            </div>

            <!-- CRUD -->
            <div class="exemplo-panel" id="panel-crud" data-panel="crud" role="tabpanel" aria-labelledby="tab-crud" hidden>
                <h2>CRUD completo</h2>
                <p>Defina GET, POST, PUT e DELETE no mesmo arquivo com tipagem automática.</p>

                <div class="code-window code-window--spaced">
                    <div class="code-window__bar">
                        <div class="code-window__dots"><span></span><span></span><span></span></div>
                        <span class="code-window__label">código</span>
                        <button class="code-window__copy" onclick="copyCode(this)">&#128203; Copiar</button>
                    </div>
                    <pre><?php echo <<<'HTML'
<span class="line-comment">// app/routes/users.[id].php</span>

<span class="line-keyword">get</span>(<span class="line-fn">fn</span>(<span class="line-var">User $user</span>) => <span class="line-var">$user</span>);

<span class="line-keyword">post</span>(<span class="line-fn">fn</span>() => <span class="line-var">User</span>::<span class="line-fn">create</span>(<span class="line-fn">input</span>()));

<span class="line-keyword">put</span>(<span class="line-fn">fn</span>(<span class="line-var">User $user</span>) => <span class="line-var">$user</span>-><span class="line-fn">update</span>(<span class="line-fn">input</span>()));

<span class="line-keyword">delete</span>(<span class="line-fn">fn</span>(<span class="line-var">User $user</span>) => <span class="line-var">$user</span>-><span class="line-fn">delete</span>());
HTML; ?></pre>
                </div>

                <button class="ex-output-btn" onclick="toggleOutput(this)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                    Ver output
                </button>

                <div class="ex-output">
<span class="output-status">// GET /users/42</span>
{
  <strong>"id"</strong>: 42,
  <strong>"name"</strong>: "Maria Silva",
  <strong>"email"</strong>: "maria@exemplo.com"
}

<span class="output-status">// POST /users → 201 Created</span>
{
  <strong>"id"</strong>: 5,
  <strong>"name"</strong>: "João",
  <strong>"email"</strong>: "joao@ex.com"
}</div>
            </div>

            <!-- Middleware -->
            <div class="exemplo-panel" id="panel-middleware" data-panel="middleware" role="tabpanel" aria-labelledby="tab-middleware" hidden>
                <h2>Middleware por arquivo</h2>
                <p>Crie um arquivo <code>_middleware.php</code> na pasta e ele se aplica a todas as rotas abaixo.</p>

                <div class="code-window code-window--spaced">
                    <div class="code-window__bar">
                        <div class="code-window__dots"><span></span><span></span><span></span></div>
                        <span class="code-window__label">código</span>
                        <button class="code-window__copy" onclick="copyCode(this)">&#128203; Copiar</button>
                    </div>
                    <pre><?php echo <<<'HTML'
<span class="line-comment">// app/routes/admin/_middleware.php</span>

<span class="line-keyword">guard</span>(<span class="line-string">'auth'</span>);
<span class="line-keyword">role</span>(<span class="line-string">'admin'</span>);

<span class="line-comment">// Todas as rotas em /admin/* agora</span>
<span class="line-comment">// exigem autenticação + role admin</span>
<span class="line-comment">// Sem registro manual, sem kernel</span>
HTML; ?></pre>
                </div>

                <button class="ex-output-btn" onclick="toggleOutput(this)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                    Ver output
                </button>

                <div class="ex-output">
<span class="output-status">// GET /admin/dashboard (sem auth)</span>
HTTP/1.1 401 Unauthorized
→ Redirect: /login

<span class="output-status">// GET /admin/dashboard (com auth + role admin)</span>
HTTP/1.1 200 OK
→ Dashboard carregado</div>
            </div>

            <!-- Validação -->
            <div class="exemplo-panel" id="panel-validation" data-panel="validation" role="tabpanel" aria-labelledby="tab-validation" hidden>
                <h2>Validação integrada</h2>
                <p>Valide input com regras encadeadas. Erros voltam automaticamente para a view ou como JSON.</p>

                <div class="code-window code-window--spaced">
                    <div class="code-window__bar">
                        <div class="code-window__dots"><span></span><span></span><span></span></div>
                        <span class="code-window__label">código</span>
                        <button class="code-window__copy" onclick="copyCode(this)">&#128203; Copiar</button>
                    </div>
                    <pre><?php echo <<<'HTML'
<span class="line-comment">// app/routes/users.php</span>

<span class="line-keyword">post</span>(<span class="line-fn">function</span> () {
    <span class="line-var">$data</span> = <span class="line-keyword">validate</span>([
        <span class="line-string">'name'</span>     => <span class="line-string">'required|min:3'</span>,
        <span class="line-string">'email'</span>    => <span class="line-string">'required|email|unique:users'</span>,
        <span class="line-string">'password'</span> => <span class="line-string">'required|min:8|confirmed'</span>,
    ]);

    <span class="line-var">$user</span> = <span class="line-var">User</span>::<span class="line-fn">create</span>(<span class="line-var">$data</span>);

    <span class="line-keyword">return</span> <span class="line-fn">response</span>(<span class="line-var">$user</span>, 201);
});
HTML; ?></pre>
                </div>

                <button class="ex-output-btn" onclick="toggleOutput(this)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                    Ver output
                </button>

                <div class="ex-output">
<span class="output-status">// Input inválido:</span>
HTTP/1.1 422 Unprocessable Entity
{
  <strong>"errors"</strong>: {
    "email": ["O email já está em uso."],
    "password": ["Mínimo 8 caracteres."]
  }
}

<span class="output-status">// Input válido:</span>
HTTP/1.1 201 Created
{ <strong>"id"</strong>: 5, <strong>"name"</strong>: "João", <strong>"email"</strong>: "joao@ex.com" }</div>
            </div>

            <!-- Auth -->
            <div class="exemplo-panel" id="panel-auth" data-panel="auth" role="tabpanel" aria-labelledby="tab-auth" hidden>
                <h2>Login & auth</h2>
                <p>Faça login, regenere a sessão e proteja páginas com <code>guard('auth')</code> sem configurar kernel ou providers separados.</p>

                <div class="code-window code-window--spaced">
                    <div class="code-window__bar">
                        <div class="code-window__dots"><span></span><span></span><span></span></div>
                        <span class="code-window__label">código</span>
                        <button class="code-window__copy" onclick="copyCode(this)">&#128203; Copiar</button>
                    </div>
                    <pre><?php echo <<<'HTML'
<span class="line-comment">// app/routes/login.php</span>

<span class="line-keyword">get</span>(<span class="line-fn">fn</span>() => <span class="line-fn">view</span>(<span class="line-string">'login'</span>));

<span class="line-keyword">post</span>(<span class="line-fn">function</span> () {
    <span class="line-var">$data</span> = <span class="line-keyword">validate</span>([
        <span class="line-string">'email'</span>    => <span class="line-string">'required|email'</span>,
        <span class="line-string">'password'</span> => <span class="line-string">'required|string'</span>,
    ]);

    <span class="line-var">$user</span> = <span class="line-var">User</span>::<span class="line-fn">where</span>(<span class="line-string">'email'</span>, <span class="line-var">$data</span>[<span class="line-string">'email'</span>])-><span class="line-fn">first</span>();

    <span class="line-keyword">if</span> (!<span class="line-var">$user</span> || !<span class="line-fn">password_verify</span>(<span class="line-var">$data</span>[<span class="line-string">'password'</span>], <span class="line-var">$user</span>->password)) {
        <span class="line-fn">flash</span>(<span class="line-string">'error'</span>, <span class="line-string">'Credenciais invalidas.'</span>);
        <span class="line-keyword">return</span> <span class="line-fn">back</span>();
    }

    <span class="line-fn">session_regenerate</span>();
    <span class="line-fn">login</span>(<span class="line-var">$user</span>);

    <span class="line-keyword">return</span> <span class="line-fn">redirect</span>(<span class="line-string">'/dashboard'</span>);
});

<span class="line-comment">// app/routes/dashboard.php</span>
<span class="line-keyword">get</span>(<span class="line-fn">fn</span>() => [<span class="line-string">'user'</span> => <span class="line-fn">auth</span>()])-><span class="line-fn">guard</span>(<span class="line-string">'auth'</span>);
HTML; ?></pre>
                </div>

                <button class="ex-output-btn" onclick="toggleOutput(this)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                    Ver output
                </button>

                <div class="ex-output">
<span class="output-status">// POST /login (credenciais invalidas)</span>
HTTP/1.1 302 Found
→ Redirect: /login
→ flash('error'): "Credenciais invalidas."

<span class="output-status">// POST /login (ok)</span>
HTTP/1.1 302 Found
→ Redirect: /dashboard
→ Sessão autenticada

<span class="output-status">// GET /dashboard</span>
{
  <strong>"user"</strong>: {
    <strong>"id"</strong>: 7,
    <strong>"name"</strong>: "Ana",
    <strong>"email"</strong>: "ana@example.com"
  }
}</div>
            </div>

            <!-- Session & Cache -->
            <div class="exemplo-panel" id="panel-session" data-panel="session" role="tabpanel" aria-labelledby="tab-session" hidden>
                <h2>Sessão & cache</h2>
                <p>Guarde preferências na sessão, devolva flash messages e use <code>cache_flexible()</code> para servir dados rápidos sem recalcular tudo a cada request.</p>

                <div class="code-window code-window--spaced">
                    <div class="code-window__bar">
                        <div class="code-window__dots"><span></span><span></span><span></span></div>
                        <span class="code-window__label">código</span>
                        <button class="code-window__copy" onclick="copyCode(this)">&#128203; Copiar</button>
                    </div>
                    <pre><?php echo <<<'HTML'
<span class="line-comment">// app/routes/settings.php</span>

<span class="line-keyword">get</span>(<span class="line-fn">function</span> () {
    <span class="line-var">$stats</span> = <span class="line-fn">cache_flexible</span>(<span class="line-string">'dashboard.stats'</span>, [30, 120], <span class="line-fn">function</span> () {
        <span class="line-keyword">return</span> [
            <span class="line-string">'users'</span> => <span class="line-var">User</span>::<span class="line-fn">count</span>(),
            <span class="line-string">'sales'</span> => <span class="line-var">Order</span>::<span class="line-fn">query</span>()-><span class="line-fn">sum</span>(<span class="line-string">'total'</span>),
        ];
    });

    <span class="line-keyword">return</span> [
        <span class="line-string">'theme'</span> => <span class="line-fn">session</span>(<span class="line-string">'theme'</span>, <span class="line-string">'light'</span>),
        <span class="line-string">'flash'</span> => <span class="line-fn">flash</span>(<span class="line-string">'success'</span>),
        <span class="line-string">'stats'</span> => <span class="line-var">$stats</span>,
    ];
});

<span class="line-keyword">post</span>(<span class="line-fn">function</span> () {
    <span class="line-fn">session</span>([<span class="line-string">'theme'</span> => <span class="line-fn">input</span>(<span class="line-string">'theme'</span>, <span class="line-string">'dark'</span>)]);
    <span class="line-fn">flash</span>(<span class="line-string">'success'</span>, <span class="line-string">'Preferencias salvas.'</span>);

    <span class="line-keyword">return</span> <span class="line-fn">back</span>();
});
HTML; ?></pre>
                </div>

                <button class="ex-output-btn" onclick="toggleOutput(this)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                    Ver output
                </button>

                <div class="ex-output">
<span class="output-status">// GET /settings</span>
HTTP/1.1 200 OK
{
  <strong>"theme"</strong>: "light",
  <strong>"flash"</strong>: null,
  <strong>"stats"</strong>: {
    <strong>"users"</strong>: 1280,
    <strong>"sales"</strong>: 93210.55
  }
}

<span class="output-status">// POST /settings</span>
HTTP/1.1 302 Found
→ Redirect: /settings
→ flash('success'): "Preferencias salvas."

<span class="output-status">// Requisições seguintes</span>
→ dashboard.stats pode ser servido como stale e renovado no shutdown</div>
            </div>

            <!-- Jobs -->
            <div class="exemplo-panel" id="panel-jobs" data-panel="jobs" role="tabpanel" aria-labelledby="tab-jobs" hidden>
                <h2>Jobs & queues</h2>
                <p>Despache processamento pesado para background e deixe a resposta HTTP curta, mesmo quando a tarefa for demorada.</p>

                <div class="code-window code-window--spaced">
                    <div class="code-window__bar">
                        <div class="code-window__dots"><span></span><span></span><span></span></div>
                        <span class="code-window__label">código</span>
                        <button class="code-window__copy" onclick="copyCode(this)">&#128203; Copiar</button>
                    </div>
                    <pre><?php echo <<<'HTML'
<span class="line-comment">// app/jobs/ProcessAvatar.php</span>

<span class="line-keyword">class</span> <span class="line-var">ProcessAvatar</span>
{
    <span class="line-keyword">public function</span> __construct(<span class="line-keyword">private</span> mixed <span class="line-var">$data</span> = null) {}

    <span class="line-keyword">public function</span> <span class="line-fn">handle</span>(): void
    {
        <span class="line-var">$path</span> = <span class="line-var">$this</span>->data[<span class="line-string">'path'</span>];

        <span class="line-var">$img</span> = <span class="line-fn">imagecreatefromjpeg</span>(<span class="line-var">$path</span>);
        <span class="line-var">$thumb</span> = <span class="line-fn">imagescale</span>(<span class="line-var">$img</span>, 200, 200);
        <span class="line-fn">imagejpeg</span>(<span class="line-var">$thumb</span>, <span class="line-fn">str_replace</span>(<span class="line-string">'.jpg'</span>, <span class="line-string">'_thumb.jpg'</span>, <span class="line-var">$path</span>));
    }
}

<span class="line-comment">// app/routes/avatar.php</span>
<span class="line-keyword">post</span>(<span class="line-fn">function</span> () {
    <span class="line-var">$file</span> = <span class="line-fn">request</span>()-><span class="line-fn">file</span>(<span class="line-string">'avatar'</span>);
    <span class="line-var">$path</span> = <span class="line-string">'storage/uploads/'</span> . <span class="line-var">$file</span>[<span class="line-string">'name'</span>];

    <span class="line-fn">move_uploaded_file</span>(<span class="line-var">$file</span>[<span class="line-string">'tmp_name'</span>], <span class="line-var">$path</span>);
    <span class="line-fn">dispatch</span>(<span class="line-var">ProcessAvatar</span>::class, [<span class="line-string">'path'</span> => <span class="line-var">$path</span>]);

    <span class="line-keyword">return</span> <span class="line-fn">json</span>([<span class="line-string">'message'</span> => <span class="line-string">'Upload recebido, processando...'</span>]);
});
HTML; ?></pre>
                </div>

                <button class="ex-output-btn" onclick="toggleOutput(this)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                    Ver output
                </button>

                <div class="ex-output">
<span class="output-status">// POST /avatar</span>
HTTP/1.1 200 OK
{
  <strong>"message"</strong>: "Upload recebido, processando..."
}

<span class="output-status">// Worker</span>
php spark queue:work
→ com QUEUE=file, o worker consome storage/queue/*.json e processa o thumbnail</div>
            </div>

            <!-- Realtime -->
            <div class="exemplo-panel" id="panel-realtime" data-panel="realtime" role="tabpanel" aria-labelledby="tab-realtime" hidden>
                <h2>Realtime</h2>
                <p>Canais file-based com SSE por padrão e WebSocket opcional para chat, notificações e fan-out em tempo real.</p>

                <div class="code-window code-window--spaced">
                    <div class="code-window__bar">
                        <div class="code-window__dots"><span></span><span></span><span></span></div>
                        <span class="code-window__label">código</span>
                        <button class="code-window__copy" onclick="copyCode(this)">&#128203; Copiar</button>
                    </div>
                    <pre><?php echo <<<'HTML'
<span class="line-comment">// app/channels/[auth]/chat.[roomId].php</span>

<span class="line-fn">channel</span>()
    -><span class="line-fn">join</span>(<span class="line-fn">function</span> (<span class="line-var">$roomId</span>) {
        <span class="line-keyword">return</span> [
            <span class="line-string">'user_id'</span> => <span class="line-fn">auth</span>()->id,
            <span class="line-string">'room_id'</span> => <span class="line-var">$roomId</span>,
        ];
    })
    -><span class="line-fn">onMessage</span>(<span class="line-string">'message.send'</span>, <span class="line-fn">function</span> (<span class="line-var">$payload</span>, <span class="line-var">$roomId</span>) {
        <span class="line-fn">realtime</span>()-><span class="line-fn">broadcast</span>(<span class="line-string">"chat.{$roomId}"</span>, <span class="line-string">'message.sent'</span>, [
            <span class="line-string">'body'</span> => <span class="line-var">$payload</span>[<span class="line-string">'body'</span>],
            <span class="line-string">'user'</span> => <span class="line-fn">auth</span>()->name,
        ]);

        <span class="line-keyword">return</span> [<span class="line-string">'ok'</span> => <span class="line-keyword">true</span>];
    });

<span class="line-comment">// public/js/chat.js</span>

<span class="line-keyword">const</span> <span class="line-var">feed</span> = <span class="line-fn">SparkRealtime</span>(<span class="line-string">'/_realtime/stream?channel=chat.42'</span>);

<span class="line-var">feed</span>.<span class="line-fn">on</span>(<span class="line-string">'message.sent'</span>, <span class="line-fn">event</span> => {
    console.<span class="line-fn">log</span>(<span class="line-string">'Nova mensagem:'</span>, <span class="line-var">event</span>.payload.body);
});

<span class="line-var">feed</span>.<span class="line-fn">connect</span>();
HTML; ?></pre>
                </div>

                <button class="ex-output-btn" onclick="toggleOutput(this)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                    Ver output
